# Anthropic API key — required unless MODEL_ADAPTER=stub
ANTHROPIC_API_KEY=

# Dev model: claude-haiku-4-5 (cheap/fast)
# Demo model: claude-sonnet-4-6 (stronger)
ANTHROPIC_MODEL=claude-haiku-4-5

# Swap the live adapter for a deterministic stub that emits canned events.
# Useful for offline demos and to prove the ModelAdapter boundary.
# Values: anthropic (default) | stub
MODEL_ADAPTER=anthropic
